rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function room(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId));
    }

    function isMember(roomId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid));
    }

    function isHost(roomId) {
      return signedIn() && room(roomId).data.hostId == request.auth.uid;
    }

    match /rooms/{roomId} {
      allow create: if signedIn() && request.resource.data.hostId == request.auth.uid;
      allow read: if signedIn();
      allow update, delete: if isHost(roomId);
      allow update: if isMember(roomId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['turnIndex', 'round', 'announcement', 'phase']);

      match /members/{memberId} {
        allow read: if signedIn();
        allow create: if signedIn() && memberId == request.auth.uid;
        allow update: if (signedIn() && memberId == request.auth.uid) || isHost(roomId);
        allow delete: if memberId == request.auth.uid || isHost(roomId);
      }

      match /players/{playerId} {
        allow read: if isMember(roomId);
        allow create: if isMember(roomId) &&
          request.resource.data.creatorId == request.auth.uid;
        allow update: if isHost(roomId) ||
          (isMember(roomId) &&
            resource.data.creatorId == request.auth.uid &&
            request.resource.data.creatorId == resource.data.creatorId);
        allow delete: if isHost(roomId) ||
          (isMember(roomId) && resource.data.creatorId == request.auth.uid);
      }

      match /picks/{pickId} {
        allow read: if isMember(roomId);
        allow create: if isMember(roomId);
        allow update, delete: if isHost(roomId);
      }

      match /nominations/{nominationId} {
        allow read: if isMember(roomId) &&
          (nominationId == request.auth.uid || room(roomId).data.phase != 'nomination');
        allow create, update: if isMember(roomId) &&
          nominationId == request.auth.uid &&
          request.resource.data.memberId == request.auth.uid;
        allow delete: if isHost(roomId) || nominationId == request.auth.uid;
      }

      match /lotteryChoices/{choiceId} {
        allow read: if isMember(roomId);
        allow create, update: if isMember(roomId) &&
          request.resource.data.memberId == request.auth.uid;
        allow delete: if isHost(roomId);
      }

      match /lineups/{memberId} {
        allow read: if isMember(roomId);
        allow create, update: if isMember(roomId) &&
          (memberId == request.auth.uid || isHost(roomId));
        allow delete: if isHost(roomId) || memberId == request.auth.uid;
      }
    }
  }
}
